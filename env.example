# VenDrop Art Engine — Environment Variables
# Copy this to .env and fill in your real keys

# ── Anthropic (Claude) — console.anthropic.com ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── fal.ai (FLUX image generation) — fal.ai → Settings → API Keys ──────────
FAL_KEY=your_fal_api_key_here
# Sign up at fal.ai — starter credits included on signup (~$5 free)
# FLUX1.1 Pro costs ~$0.04–0.06 per image at print resolution

# ── Printify — printify.com/app/settings/api ────────────────────────────────
PRINTIFY_API_TOKEN=your_printify_token_here
PRINTIFY_SHOP_ID=your_shop_id_here   # optional, auto-detected if blank
